<Window x:Class="Phonova.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:local="clr-namespace:Phonova"
        mc:Ignorable="d"
        Title="Phonova - Dashboard" 
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="#F5F6F8"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="SidebarDarkBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="BrandPrimaryBrush" Color="#FBC101"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderColorBrush" Color="#E5E7EB"/>

        <!-- Icon Button Style -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green Icon Button -->
        <Style x:Key="GreenIconBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Background" Value="#FBC101"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D5A300"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Red Icon Button -->
        <Style x:Key="RedIconBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Bar -->
        <Border Grid.Row="0" Background="{StaticResource SidebarDarkBrush}" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Image Grid.Column="0" 
                                Source="Assets/logo_main.png" 
                                Height="28" 
                                Stretch="Uniform" 
                                VerticalAlignment="Center"
                                Margin="0,0,16,0"/>

                <!-- Device Count -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Border Background="#334155" CornerRadius="4" Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CellphoneLink" Width="16" Height="16" Foreground="#FBC101" VerticalAlignment="Center"/>
                            <TextBlock x:Name="DeviceCountText" Text="0" FontSize="13" FontWeight="SemiBold" Foreground="White" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="devices" FontSize="11" Foreground="#94A3B8" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="•" FontSize="11" Foreground="#475569" Margin="8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SelectedCountText" Text="0 selected" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

 
                    <!-- Select / Deselect All -->
                    <Button x:Name="SelectAllBtn" Style="{StaticResource IconBtn}" ToolTip="Select All" Click="SelectAllBtn_Click">
                        <materialDesign:PackIcon Kind="CheckboxMultipleMarked" Width="18" Height="18"/>
                    </Button>
                    <Button x:Name="DeselectAllBtn" Style="{StaticResource IconBtn}" ToolTip="Deselect All" Click="DeselectAllBtn_Click">
                        <materialDesign:PackIcon Kind="CheckboxMultipleBlankOutline" Width="18" Height="18"/>
                    </Button>
 
                    <Border Width="1" Background="#475569" Height="20" Margin="6,0"/>

                    <Button x:Name="RebootBatchBtn" Style="{StaticResource IconBtn}" ToolTip="Reboot Selected" Click="RebootAllBtn_Click" IsEnabled="False">
                        <materialDesign:PackIcon Kind="Restart" Width="18" Height="18"/>
                    </Button>
                    <Button x:Name="ShutdownBatchBtn" Style="{StaticResource IconBtn}" ToolTip="Shutdown Selected" Click="ShutdownAllBtn_Click" IsEnabled="False">
                        <materialDesign:PackIcon Kind="Power" Width="18" Height="18"/>
                    </Button>
                    <Button x:Name="BatteryBatchBtn" Style="{StaticResource IconBtn}" ToolTip="Adjust Battery Selected" Click="BatteryBatchBtn_Click" IsEnabled="False">
                        <materialDesign:PackIcon Kind="BatteryPlus" Width="18" Height="18"/>
                    </Button>
                    <Button x:Name="WipeBatchBtn" Style="{StaticResource RedIconBtn}" ToolTip="Wipe Selected" Click="WipeAllBtn_Click" IsEnabled="False">
                        <materialDesign:PackIcon Kind="DeleteForever" Width="18" Height="18"/>
                    </Button>

                    <Border Width="1" Background="#475569" Height="20" Margin="6,0"/>

                    <Button x:Name="HeaderCustomerBtn" Style="{StaticResource IconBtn}" Width="Auto" Padding="12,0" ToolTip="Select Customer" Click="HeaderCustomerBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Account" Width="16" Height="16" VerticalAlignment="Center" Foreground="#FBC101"/>
                            <TextBlock x:Name="HeaderCustomerText" Text="Select Customer" FontSize="12" Margin="6,0,12,0" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="HeaderCustomerClearBtn" Style="{StaticResource IconBtn}" Width="Auto" Padding="6,0" Margin="-4,0,0,0" ToolTip="Clear Customer Selection" Click="HeaderCustomerClearBtn_Click" Visibility="Collapsed">
                        <materialDesign:PackIcon Kind="CloseCircle" Width="16" Height="16" VerticalAlignment="Center" Foreground="#EF4444"/>
                    </Button>


                    <Button x:Name="HeaderMmrCommentBtn" Style="{StaticResource IconBtn}" Width="Auto" Padding="12,0" ToolTip="Select MMR Comment" Click="HeaderMmrCommentBtn_Click" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CommentAlert" Width="16" Height="16" VerticalAlignment="Center" Foreground="#F59E0B"/>
                            <TextBlock x:Name="HeaderMmrCommentText" Text="Select MMR Comment" FontSize="12" Margin="6,0,12,0" VerticalAlignment="Center" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="HeaderMmrCommentClearBtn" Style="{StaticResource IconBtn}" Width="Auto" Padding="6,0" Margin="-4,0,0,0" ToolTip="Clear MMR Comment Selection" Click="HeaderMmrCommentClearBtn_Click" Visibility="Collapsed">
                        <materialDesign:PackIcon Kind="CloseCircle" Width="16" Height="16" VerticalAlignment="Center" Foreground="#EF4444"/>
                    </Button>
                </StackPanel>

                <!-- Right Side - Dashboard & Window Controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <!-- Company & Fuel Details with Logo -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock x:Name="CompanyText" Text="Company" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                            <TextBlock x:Name="FuelText" Text="Fuel: --" FontSize="10" Foreground="#A0AEC0" HorizontalAlignment="Right"/>
                        </StackPanel>
                        <Border Width="28" Height="28" Background="#1E293B" CornerRadius="4" VerticalAlignment="Center" Margin="8,0,0,0">
                            <Grid>
                                <materialDesign:PackIcon x:Name="CompanyLogoPlaceholder" Kind="Domain" Width="18" Height="18" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image x:Name="CompanyLogoImage" Width="28" Height="28" Stretch="UniformToFill" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Internet Status Indicator -->
                    <Border x:Name="InternetStatusBorder" Background="Transparent" VerticalAlignment="Center" Margin="0,0,8,0" ToolTip="Checking Internet...">
                        <materialDesign:PackIcon x:Name="InternetStatusIcon" Kind="Wifi" Width="20" Height="20" Foreground="#10B981"/>
                    </Border>

                    <TextBlock x:Name="SyncStatusText" Text="• 0 pending" Foreground="#FB923C" FontSize="11" Margin="4,0" VerticalAlignment="Center" Visibility="Collapsed"/>

                    <!-- Divider after Internet Status -->
                    <Border Width="1" Background="#475569" Margin="6,8"/>

                    <Button x:Name="SettingsBtn" Style="{StaticResource GreenIconBtn}" Width="36" Padding="0" ToolTip="Settings" Click="SettingsBtn_Click" Margin="6,0,0,0">
                        <materialDesign:PackIcon Kind="Gear" Width="18" Height="18"/>
                    </Button>
                    
                    <Button x:Name="PortmapBtn" Style="{StaticResource GreenIconBtn}" Width="36" Padding="0" ToolTip="Portmap" Click="PortmapBtn_Click" Margin="6,0,0,0">
                        <materialDesign:PackIcon Kind="UsbPort" Width="18" Height="18"/>
                    </Button>
 
                    <Border Width="1" Background="#475569" Margin="12,8"/>
 
                    <Button x:Name="MinimizeBtn" Style="{StaticResource IconBtn}" ToolTip="Minimize" Click="MinimizeBtn_Click">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                    </Button>
                    <Button x:Name="CloseBtn" Style="{StaticResource RedIconBtn}" ToolTip="Close" Click="CloseBtn_Click">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Insufficient Fuel Banner -->
        <Border x:Name="FuelBanner"
                Grid.Row="1"
                Visibility="Collapsed"
                Padding="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7F1D1D" Offset="0"/>
                    <GradientStop Color="#991B1B" Offset="0.5"/>
                    <GradientStop Color="#7F1D1D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Banner Content -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10">
                    <Border Background="#EF4444" CornerRadius="20" Width="28" Height="28" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="AlertOctagon" Width="16" Height="16" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Orientation="Vertical" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Insufficient Fuel" FontSize="13" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="FuelBannerSubText"
                                   Text="Your account has run out of test fuel. Test results are being held locally and will sync automatically once fuel is added."
                                   FontSize="11" Foreground="#FCA5A5" TextWrapping="NoWrap"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right side: held count pill + action -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Border Background="#EF4444" CornerRadius="12" Padding="10,4" VerticalAlignment="Center" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseClock" Width="13" Height="13" Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock x:Name="FuelBannerHeldText" Text="0 tests held" FontSize="11" FontWeight="SemiBold" Foreground="White" Margin="5,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="Contact your administrator to top up fuel."
                               FontSize="11" Foreground="#FECACA" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Device Cards Grid Area -->
        <Border Grid.Row="2" Padding="16">
            <Grid>
                <!-- Scrollable Device Cards -->
                <ScrollViewer VerticalScrollBarVisibility="Hidden" 
                              HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="DeviceCardsPanel" 
                               Orientation="Horizontal">
                        <!-- Managed by code -->
                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
