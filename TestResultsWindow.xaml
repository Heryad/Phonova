<Window x:Class="Phonova.TestResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Test Results" 
        Height="800" Width="550"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="HeaderBg" Color="#1E293B"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="GreenColor" Color="#10B981"/>
        <SolidColorBrush x:Key="RedColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="YellowColor" Color="#F59E0B"/>
        <SolidColorBrush x:Key="BrandPrimary" Color="#027dfe"/>

        <!-- Label Style -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- Value Style -->
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6BA366"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="{StaticResource BrandPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6B5A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Test Result Item Style -->
        <Style x:Key="TestResultItem" TargetType="Border">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Rotating Animation for Spinner -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation 
                Storyboard.TargetName="SpinnerRotate"
                Storyboard.TargetProperty="Angle"
                From="0" To="360" Duration="0:0:1.2"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- Main Card with Shadow -->
    <Border Background="{StaticResource CardBg}" 
            CornerRadius="12" 
            Margin="20"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TEST RESULTS" FontSize="10" Foreground="#94A3B8" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DeviceNameText" Text="-" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SerialText" Text="-" FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Grid.Column="1" 
                            x:Name="CloseBtn"
                            Width="36" Height="36"
                            Background="#374151"
                            BorderThickness="0"
                            Cursor="Hand"
                            VerticalAlignment="Top"
                            Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>
                    
                    <!-- Overall Status -->
                    <Border x:Name="OverallStatusBorder" Background="#DEF7EC" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <materialDesign:PackIcon x:Name="OverallStatusIcon" Kind="CheckCircle" Width="28" Height="28" Foreground="#10B981" VerticalAlignment="Center"/>
                            <StackPanel Margin="12,0,0,0">
                                <TextBlock x:Name="OverallStatusText" Text="ALL TESTS PASSED" FontSize="14" FontWeight="Bold" Foreground="#10B981"/>
                                <TextBlock x:Name="OverallStatusSubtext" Text="Device is in excellent condition" FontSize="11" Foreground="#6B7280"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Device Info Section -->
                    <TextBlock Text="DEVICE INFORMATION" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                    <Border Background="#F9FAFB" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="MODEL" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="ModelText" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="STORAGE" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="StorageText" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="IMEI" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="Imei1Text" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="iOS VERSION" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="IosVersionText" Text="-" Style="{StaticResource ValueText}"/>
                                <TextBlock x:Name="Imei2Text" Text="-" Style="{StaticResource ValueText}" Visibility="Collapsed"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                                <TextBlock Text="BATTERY HEALTH" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="BatteryText" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                                <TextBlock Text="BATTERY CYCLES" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="BatteryCyclesText" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="0">
                                <TextBlock Text="REGION" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="RegionText" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="3" Grid.Column="1">
                                <TextBlock Text="COLOR" Style="{StaticResource LabelText}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="ColorDot" Width="12" Height="12" Fill="Transparent" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ColorText" Text="-" Style="{StaticResource ValueText}" Margin="6,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Lock Status Section -->
                    <TextBlock Text="LOCK STATUS" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource TestResultItem}" Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="iCloud" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <Border x:Name="IcloudBadge" Background="#F3F4F6" CornerRadius="4" Padding="8,4" Margin="0,4,0,0">
                                    <TextBlock x:Name="IcloudText" Text="-" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource TestResultItem}" Margin="2,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="FMI" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <Border x:Name="FmiBadge" Background="#F3F4F6" CornerRadius="4" Padding="8,4" Margin="0,4,0,0">
                                    <TextBlock x:Name="FmiText" Text="-" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource TestResultItem}" Margin="2,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="MDM" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <Border x:Name="MdmBadge" Background="#F3F4F6" CornerRadius="4" Padding="8,4" Margin="0,4,0,0">
                                    <TextBlock x:Name="MdmText" Text="-" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource TestResultItem}" Margin="4,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="SIM Status" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                <Border x:Name="SimBadge" Background="#F3F4F6" CornerRadius="4" Padding="8,4" Margin="0,4,0,0">
                                    <TextBlock x:Name="SimText" Text="-" FontSize="10" FontWeight="Bold" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Component Validation Section -->
                    <TextBlock Text="COMPONENT VALIDATION" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                    <Border Background="#F9FAFB" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <WrapPanel x:Name="ComponentPanel">
                            <!-- Items like LCD, Battery, FaceID will be added here -->
                        </WrapPanel>
                    </Border>

                    <!-- Dynamic Test Results Section -->
                    <TextBlock Text="TEST RESULTS" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                    <StackPanel x:Name="TestResultsPanel">
                        <!-- Items will be added dynamically -->
                    </StackPanel>

                    <!-- Test Info -->
                    <Border Background="#F9FAFB" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TEST DATE" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="TestDateText" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="TESTER" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="TesterText" Text="-" Style="{StaticResource ValueText}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Comments Section -->
                    <StackPanel x:Name="CommentsSection" Visibility="Collapsed" Margin="0,16,0,0">
                        <TextBlock Text="COMMENTS" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
                        <Border Background="#FEF3C7" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="CommentText" Width="16" Height="16" Foreground="#D97706" VerticalAlignment="Center"/>
                                    <TextBlock Text="Applied Comments" FontWeight="SemiBold" FontSize="12" Foreground="#92400E" Margin="8,0,0,0"/>
                                </StackPanel>
                                <StackPanel x:Name="CommentsListPanel">
                                    <!-- Comments will be added dynamically -->
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer with Action Buttons -->
            <Border Grid.Row="2" Padding="20,16" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>



                    <Button x:Name="CertificateBtn" Grid.Column="2" Style="{StaticResource SecondaryBtn}" Click="CertificateBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Certificate" Width="18" Height="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Certificate" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Loading Overlay -->
            <Grid x:Name="LoadingOverlay" Grid.RowSpan="3" Visibility="Collapsed">
                <Border Background="#CCFFFFFF" CornerRadius="12"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Custom Spinner from SplashScreen -->
                    <Grid HorizontalAlignment="Center" Width="44" Height="44">
                        <Ellipse Width="44" Height="44" 
                                 Stroke="#E5E7EB" StrokeThickness="3"/>
                        <Path Stroke="{StaticResource BrandPrimary}" StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 22,0 A 22,22 0 0 1 44,22"
                              RenderTransformOrigin="0.5,0.5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Width="44" Height="44">
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>
                    
                    <TextBlock Text="Generating Certificate..." 
                               Margin="0,16,0,0" 
                               FontSize="14" 
                               FontWeight="SemiBold" 
                               Foreground="{StaticResource BrandPrimary}"/>
                    <TextBlock Text="Please wait a moment" 
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0" 
                               FontSize="12" 
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
