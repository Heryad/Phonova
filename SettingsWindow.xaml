<Window x:Class="Dyagnoz_Latest.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        Title="Settings" Height="800" Width="1320"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBg" Color="#1E293B"/>
        <SolidColorBrush x:Key="HeaderBg" Color="#1E293B"/>
        <SolidColorBrush x:Key="BrandGreen" Color="#7FB679"/>
        <SolidColorBrush x:Key="BrandPurple" Color="#53427D"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="ContentBg" Color="#F5F6F8"/>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{StaticResource BrandGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6BA366"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="{StaticResource BrandPurple}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6B5A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bg" Background="#D1D5DB" CornerRadius="12" Padding="2">
                            <Ellipse x:Name="dot" Width="20" Height="20" Fill="White" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#7FB679"/>
                                <Setter TargetName="dot" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Card with Shadow -->
    <Border Background="{StaticResource CardBg}" CornerRadius="12" Margin="20" SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Bar -->
            <Border Grid.Row="0" Background="{StaticResource HeaderBg}" CornerRadius="12,12,0,0" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SETTINGS" FontSize="10" Foreground="#94A3B8" FontWeight="Medium" Margin="0,0,0,4"/>
                        <TextBlock Text="Dyagnoz Configuration" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="CloseBtn" Width="36" Height="36" Background="#374151" BorderThickness="0" Cursor="Hand" VerticalAlignment="Top" Click="CloseBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
                    <StackPanel Margin="0,16,0,0">
                        <Button x:Name="NavDashboard" Style="{StaticResource NavBtnActive}" Click="NavDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavReports" Style="{StaticResource NavBtn}" Click="NavReports_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileDocument" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Reports" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavTests" Style="{StaticResource NavBtn}" Click="NavTests_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ClipboardCheck" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Tests" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavComments" Style="{StaticResource NavBtn}" Click="NavComments_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CommentText" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Comments" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavWifi" Style="{StaticResource NavBtn}" Click="NavWifi_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Wifi" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="WiFi Settings" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavTestFlow" Style="{StaticResource NavBtn}" Click="NavTestFlow_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlayCircle" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="Test Flow" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavLicense" Style="{StaticResource NavBtn}" Click="NavLicense_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="License" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="License" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavAbout" Style="{StaticResource NavBtn}" Click="NavAbout_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Information" Width="20" Height="20" VerticalAlignment="Center"/>
                                <TextBlock Text="About" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Content Area -->
                <Border Grid.Column="1" Background="{StaticResource ContentBg}" CornerRadius="0,0,12,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20">
                        <Grid>
                            <!-- Dashboard Panel -->
                            <StackPanel x:Name="PanelDashboard" Visibility="Visible">
                                <TextBlock Text="Dashboard" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,16">
                                        <StackPanel>
                                            <TextBlock Text="Total Tests" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="StatTotalTests" Text="0" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,8,16">
                                        <StackPanel>
                                            <TextBlock Text="Passed" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="StatPassed" Text="0" FontSize="28" FontWeight="Bold" Foreground="#10B981"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,8,16">
                                        <StackPanel>
                                            <TextBlock Text="Failed" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="StatFailed" Text="0" FontSize="28" FontWeight="Bold" Foreground="#EF4444"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="8,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Success Rate" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="StatSuccessRate" Text="0%" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrandGreen}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Chart Area -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Test Results by Device" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,16"/>
                                        <Grid Height="200">
                                            <Canvas x:Name="ChartCanvas" Background="Transparent"/>
                                            <!-- Empty state overlay -->
                                            <StackPanel x:Name="ChartEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ChartBar" Width="48" Height="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                                                <TextBlock Text="No data to display" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <!-- Legend -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                <Border Width="16" Height="16" Background="#10B981" CornerRadius="2"/>
                                                <TextBlock Text="Pass" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="16" Height="16" Background="#EF4444" CornerRadius="2"/>
                                                <TextBlock Text="Fail" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- Line Chart - Devices by Date -->
                                <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Devices Tested by Day (Last 7 Days)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,16"/>
                                        <Grid Height="150">
                                            <Canvas x:Name="LineChartCanvas" Background="Transparent"/>
                                            <StackPanel x:Name="LineChartEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <materialDesign:PackIcon Kind="ChartLine" Width="48" Height="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
                                                <TextBlock Text="No data to display" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Reports Panel -->
                            <StackPanel x:Name="PanelReports" Visibility="Collapsed">
                                <TextBlock Text="Reports" Style="{StaticResource SectionTitle}"/>
                                
                                <!-- Reports Stats -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Total Matched" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="ReportStatTotal" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Passed" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="ReportStatPassed" Text="0" FontSize="20" FontWeight="Bold" Foreground="#10B981"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="Failed" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="ReportStatFailed" Text="0" FontSize="20" FontWeight="Bold" Foreground="#EF4444"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Pass Ratio" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock x:Name="ReportStatRatio" Text="0%" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandGreen}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <!-- Search and Filter Bar -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <Border Grid.Column="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,8,0">
                                                <TextBox x:Name="ReportSearchBox" BorderThickness="0" Padding="12,10" FontSize="13" VerticalAlignment="Center" materialDesign:HintAssist.Hint="Search IMEI, Serial, or Name..." KeyDown="ReportSearchBox_KeyDown"/>
                                            </Border>
                                            
                                            <DatePicker Grid.Column="1" x:Name="StartDatePicker" materialDesign:HintAssist.Hint="From Date" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <DatePicker Grid.Column="2" x:Name="EndDatePicker" materialDesign:HintAssist.Hint="To Date" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            
                                            <Button Grid.Column="3" Style="{StaticResource ActionBtn}" Margin="0,0,8,0" Click="SearchReports_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Magnify" Width="16" Height="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Search" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                            
                                            <Button Grid.Column="4" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0" Click="ResetReportFilters_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Reset" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Grid.Column="5" Style="{StaticResource ActionBtn}" Background="#334155" Click="ExportReports_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="FileExport" Width="16" Height="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Export" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <!-- Reports Table -->
                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Background="White">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- Header -->
                                                <Grid Grid.Row="0" Background="#F9FAFB">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>     <!-- Device / Model -->
                                                        <ColumnDefinition Width="120"/>   <!-- IMEI -->
                                                        <ColumnDefinition Width="120"/>   <!-- Serial -->
                                                        <ColumnDefinition Width="140"/>   <!-- Date -->
                                                        <ColumnDefinition Width="100"/>   <!-- Status -->
                                                        <ColumnDefinition Width="80"/>    <!-- Actions -->
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Device Info" FontWeight="SemiBold" Padding="12,12" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Grid.Column="1" Text="IMEI" FontWeight="SemiBold" Padding="12,12" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Grid.Column="2" Text="Serial" FontWeight="SemiBold" Padding="12,12" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Grid.Column="3" Text="Date &amp; Time" FontWeight="SemiBold" Padding="12,12" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                                    <TextBlock Grid.Column="4" Text="Result" FontWeight="SemiBold" Padding="12,12" FontSize="12" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                                    <TextBlock Grid.Column="5" Text="Actions" FontWeight="SemiBold" Padding="12,12" FontSize="12" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                                                </Grid>
                                                
                                                <!-- Content -->
                                                <ScrollViewer Grid.Row="1" MaxHeight="500" VerticalScrollBarVisibility="Auto">
                                                    <StackPanel x:Name="ReportsTablePanel"/>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Tests Panel -->
                            <StackPanel x:Name="PanelTests" Visibility="Collapsed">
                                <TextBlock Text="Test Settings" Style="{StaticResource SectionTitle}"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel x:Name="TestConfigPanel">
                                        <!-- Dynamic tests generated here -->
                                    </StackPanel>
                                </Border>
                                <Button Content="Save Test Configuration" Style="{StaticResource ActionBtn}" Margin="0,0,0,0" Click="SaveTestConfig_Click" HorizontalAlignment="Left" />
                            </StackPanel>

                            <!-- Comments Panel -->
                            <StackPanel x:Name="PanelComments" Visibility="Collapsed">
                                <TextBlock Text="Comment Templates" Style="{StaticResource SectionTitle}"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <!-- Add new comment -->
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Background="White" Margin="0,0,8,0">
                                                <TextBox x:Name="NewCommentBox" BorderThickness="0" Padding="12,10" FontSize="13" VerticalAlignment="Center" materialDesign:HintAssist.Hint="Enter new comment template..."/>
                                            </Border>
                                            <Button Grid.Column="1" Style="{StaticResource ActionBtn}" Click="AddCommentBtn_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Add" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <!-- Comments table -->
                                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- Header -->
                                                <Grid Grid.Row="0" Background="#F9FAFB">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Comment" FontWeight="SemiBold" Padding="12,10"/>
                                                    <TextBlock Grid.Column="1" Text="Actions" FontWeight="SemiBold" Padding="12,10"/>
                                                </Grid>
                                                <!-- Dynamic rows -->
                                                <StackPanel x:Name="CommentsTablePanel" Grid.Row="1">
                                                    <!-- Rows will be added dynamically -->
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>



                            <!-- WiFi Panel -->
                            <StackPanel x:Name="PanelWifi" Visibility="Collapsed">
                                <TextBlock Text="WiFi Settings" Style="{StaticResource SectionTitle}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                <Border Background="#EEF2FF" CornerRadius="8" Padding="12">
                                                    <materialDesign:PackIcon Kind="WifiCog" Width="28" Height="28" Foreground="#6366F1"/>
                                                </Border>
                                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Network Configuration" FontSize="16" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Configure WiFi profile to push to devices" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Text="Network Name (SSID)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <TextBox x:Name="WifiSsidBox" Padding="12" Margin="0,0,0,16"/>
                                            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <PasswordBox x:Name="WifiPasswordBox" Padding="12" Margin="0,0,0,24"/>
                                            <Button Style="{StaticResource ActionBtn}" HorizontalAlignment="Stretch" Click="SaveWifiBtn_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Save WiFi Profile" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                <Border Background="#ECFDF5" CornerRadius="8" Padding="12">
                                                    <materialDesign:PackIcon Kind="WifiCheck" Width="28" Height="28" Foreground="#10B981"/>
                                                </Border>
                                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="Saved Profiles" FontSize="16" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Quick-select from saved networks" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <StackPanel x:Name="WifiProfilesPanel" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <!-- Test Flow Panel -->
                            <StackPanel x:Name="PanelTestFlow" Visibility="Collapsed">
                                <TextBlock Text="Test Flow &amp; Printing" Style="{StaticResource SectionTitle}"/>
                                
                                <!-- Test Flow Section -->
                                <TextBlock Text="Test Flow" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,8"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel><TextBlock Text="Full Test" FontWeight="SemiBold"/><TextBlock Text="Run complete diagnostic pipeline" Foreground="{StaticResource TextSecondary}" FontSize="12"/></StackPanel>
                                            <ToggleButton x:Name="FullTestToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="FlowToggle_Click"/>
                                        </Grid>
                                        <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,16"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel><TextBlock Text="Activation Only" FontWeight="SemiBold"/><TextBlock Text="Skip diagnostics, only activate device" Foreground="{StaticResource TextSecondary}" FontSize="12"/></StackPanel>
                                            <ToggleButton x:Name="ActivationOnlyToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="FlowToggle_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Post Test Section -->
                                <TextBlock Text="Post Test" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,8"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel><TextBlock Text="Print Label" FontWeight="SemiBold"/><TextBlock Text="Auto print label on success" Foreground="{StaticResource TextSecondary}" FontSize="12"/></StackPanel>
                                            <ToggleButton x:Name="AutoPrintToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                        <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,16"/>
                                        <Grid Margin="0,0,0,16">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel><TextBlock Text="Wipe Device" FontWeight="SemiBold"/><TextBlock Text="Factory reset after processing" Foreground="{StaticResource TextSecondary}" FontSize="12"/></StackPanel>
                                            <ToggleButton x:Name="AutoWipeToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                        <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,16"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <StackPanel><TextBlock Text="Shutdown Device" FontWeight="SemiBold"/><TextBlock Text="Power off after processing" Foreground="{StaticResource TextSecondary}" FontSize="12"/></StackPanel>
                                            <ToggleButton x:Name="AutoShutdownToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Print Settings Section -->
                                <TextBlock Text="Print Settings" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,8"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Print failed parts" VerticalAlignment="Center"/>
                                            <ToggleButton x:Name="PrintFailedPartsToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Print part messages" VerticalAlignment="Center"/>
                                            <ToggleButton x:Name="PrintPartMessagesToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Print customer name" VerticalAlignment="Center"/>
                                            <ToggleButton x:Name="PrintCustomerNameToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Print tester name" VerticalAlignment="Center"/>
                                            <ToggleButton x:Name="PrintTesterNameToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Text="Print port number" VerticalAlignment="Center"/>
                                            <ToggleButton x:Name="PrintPortNumberToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}" Click="SettingToggle_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- License Panel -->
                            <StackPanel x:Name="PanelLicense" Visibility="Collapsed">
                                <TextBlock Text="License" Style="{StaticResource SectionTitle}"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <Border Background="#ECFDF5" CornerRadius="8" Padding="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,12">
                                                <materialDesign:PackIcon Kind="CheckCircle" Width="24" Height="24" Foreground="#10B981"/>
                                            </Border>
                                            <TextBlock Text="Total Licenses" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock Text="500" FontSize="32" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,8,0">
                                        <StackPanel>
                                            <Border Background="#FEF3C7" CornerRadius="8" Padding="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,12">
                                                <materialDesign:PackIcon Kind="Fire" Width="24" Height="24" Foreground="#F59E0B"/>
                                            </Border>
                                            <TextBlock Text="Consumed" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock Text="347" FontSize="32" FontWeight="Bold" Foreground="#F59E0B"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                        <StackPanel>
                                            <Border Background="#EEF2FF" CornerRadius="8" Padding="10" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,0,12">
                                                <materialDesign:PackIcon Kind="Gift" Width="24" Height="24" Foreground="#6366F1"/>
                                            </Border>
                                            <TextBlock Text="Remaining" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            <TextBlock Text="153" FontSize="32" FontWeight="Bold" Foreground="#6366F1"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="License Details" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                            <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Status" Foreground="{StaticResource TextSecondary}"/>
                                                <Border Grid.Column="1" Background="#DEF7EC" CornerRadius="4" Padding="12,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="Active" Foreground="#10B981" FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                            <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="License Key" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="XXXX-XXXX-XXXX-XXXX" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Expires" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="Dec 31, 2026" FontWeight="SemiBold"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Refill License" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>
                                            <TextBlock Text="Enter your refill code to add more licenses" Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,0,0,16"/>
                                            <TextBlock Text="Refill Code" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <TextBox Padding="12" Margin="0,0,0,16"/>
                                            <Button Style="{StaticResource ActionBtn}" HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Apply Refill Code" Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <!-- About Panel -->
                            <StackPanel x:Name="PanelAbout" Visibility="Collapsed">
                                <TextBlock Text="About" Style="{StaticResource SectionTitle}"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#1E293B" CornerRadius="12" Padding="32" Margin="0,0,24,0">
                                            <svgc:SvgViewbox Source="Assets/logo.svg" Height="80" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Dyagnoz" FontSize="28" FontWeight="Bold" Foreground="{StaticResource BrandGreen}"/>
                                            <TextBlock Text="Device Diagnostics Platform" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,4,0,20"/>
                                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Version" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="1.0.0" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Build" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="2026.01.31" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Website" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="www.dyagnoz.com" FontWeight="SemiBold" Foreground="{StaticResource BrandGreen}"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="100"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <TextBlock Text="Support" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="support@dyagnoz.com" FontWeight="SemiBold"/>
                                            </Grid>
                                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,12,0,12"/>
                                            <TextBlock Text="© 2026 Dyagnoz. All rights reserved." Foreground="{StaticResource TextSecondary}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
