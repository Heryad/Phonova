<Window x:Class="Phonova.LoginScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:local="clr-namespace:Phonova"
        mc:Ignorable="d"
        Title="Phonova - Diagnostic Management System" 
        Height="640" Width="980"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Your Brand Colors -->
        <Color x:Key="BrandPrimary">#027dfe</Color>
        <Color x:Key="SidebarDark">#1E293B</Color>
        <Color x:Key="LightBackground">#F5F6F8</Color>
        <Color x:Key="CardWhite">#FFFFFF</Color>
        <Color x:Key="TextPrimary">#1A1A2E</Color>
        <Color x:Key="TextSecondary">#6B7280</Color>
        <Color x:Key="BorderColor">#D1D5DB</Color>

        <SolidColorBrush x:Key="BrandPrimaryBrush" Color="{StaticResource BrandPrimary}"/>
        <SolidColorBrush x:Key="SidebarDarkBrush" Color="{StaticResource SidebarDark}"/>
        <SolidColorBrush x:Key="LightBackgroundBrush" Color="{StaticResource LightBackground}"/>
        <SolidColorBrush x:Key="CardWhiteBrush" Color="{StaticResource CardWhite}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BorderColorBrush" Color="{StaticResource BorderColor}"/>

        <!-- Clean Input Style - No Blur Effects -->
        <Style x:Key="CleanInput" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="36,0,14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clean Password Style -->
        <Style x:Key="CleanPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="36,0,40,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrandPrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Clean ComboBox Style -->
        <Style x:Key="CleanComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="36,0,14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" 
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    Margin="{TemplateBinding Padding}"
                                                    VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="1" 
                                                Focusable="False"
                                                IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                ClickMode="Press"
                                                Background="Transparent"
                                                BorderThickness="0">
                                        <materialDesign:PackIcon Kind="ChevronDown" 
                                                               Width="18" Height="18"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="White" 
                                        BorderBrush="{StaticResource BorderColorBrush}" 
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Margin="0,2,0,0"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer MaxHeight="180" SnapsToDevicePixels="True">
                                        <ItemsPresenter SnapsToDevicePixels="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="{StaticResource BrandPrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#026bd9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#015ab5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Buttons -->
        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Container -->
    <Border Background="White" CornerRadius="6" SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Branding with Your Colors -->
            <Border Grid.Column="0" Background="{StaticResource SidebarDarkBrush}" CornerRadius="6,0,0,6">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <!-- Your Logo - 40% bigger -->
                        <Image Source="Assets/app_logo.png" 
                               Height="68" Width="252" 
                               Stretch="Uniform" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,0"/>

                        <!-- Divider -->
                        <Border Height="1" 
                                Background="White" 
                                Opacity="0.2" 
                                Margin="0,36,0,36"
                                Width="180"/>

                        <!-- Features -->
                        <StackPanel HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="CheckCircle" 
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrandPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                <TextBlock Text="Real-time Diagnostics" 
                                           Foreground="White"
                                           Opacity="0.9"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <materialDesign:PackIcon Kind="CheckCircle" 
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrandPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                <TextBlock Text="Automated Testing" 
                                           Foreground="White"
                                           Opacity="0.9"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" 
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource BrandPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"/>
                                <TextBlock Text="Secure Data Handling" 
                                           Foreground="White"
                                           Opacity="0.9"
                                           FontSize="12"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Version -->
                    <TextBlock Text="Version 1.0.0.124" 
                               FontSize="10"
                               Foreground="White"
                               Opacity="0.5"
                               VerticalAlignment="Bottom"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                </Grid>
            </Border>

            <!-- Right Panel - Login Form -->
            <Grid Grid.Column="1" Background="{StaticResource LightBackgroundBrush}">
                <!-- Window Controls -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top" 
                            Margin="0,10,10,0">
                    <Button Style="{StaticResource WindowButton}" Click="MinimizeButton_Click">
                        <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16" Foreground="#6B7280"/>
                    </Button>
                    <Button Style="{StaticResource CloseWindowButton}" Click="CloseButton_Click" Margin="4,0,0,0">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="#6B7280"/>
                    </Button>
                </StackPanel>

                <!-- Form Card -->
                <Border Background="White"
                        CornerRadius="6"
                        Padding="36"
                        Margin="40"
                        VerticalAlignment="Center"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        SnapsToDevicePixels="True"
                        MouseDown="Border_MouseDown">

                    <StackPanel Width="300">
                        <!-- Header -->
                        <TextBlock Text="Welcome back" 
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="Sign in to access the system" 
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,28"/>

                        <!-- Operator ID -->
                        <TextBlock Text="Operator ID" 
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <TextBox x:Name="UsernameBox" Style="{StaticResource CleanInput}"/>
                            <materialDesign:PackIcon Kind="AccountOutline" 
                                                   Width="18" Height="18"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   IsHitTestVisible="False"/>
                        </Grid>

                        <!-- Password -->
                        <TextBlock Text="Password" 
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,16">
                            <PasswordBox x:Name="PasswordBox" Style="{StaticResource CleanPasswordBox}"/>
                            <materialDesign:PackIcon Kind="LockOutline" 
                                                   Width="18" Height="18"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   IsHitTestVisible="False"/>
                            <Button Width="32" Height="32"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource WindowButton}"
                                    Click="TogglePasswordVisibility_Click"
                                    Margin="0,0,6,0">
                                <materialDesign:PackIcon x:Name="PasswordVisibilityIcon"
                                                       Kind="EyeOffOutline" 
                                                       Width="16" Height="16"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>

                        <!-- Workstation -->
                        <TextBlock Text="Workstation / Tester" 
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Segoe UI"
                                   Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,24">
                            <ComboBox x:Name="TestorComboBox" Style="{StaticResource CleanComboBox}">
                                <ComboBoxItem Content="Tester Station A1" IsSelected="True"/>
                                <ComboBoxItem Content="Tester Station A2"/>
                                <ComboBoxItem Content="Tester Station B1"/>
                                <ComboBoxItem Content="Lab Supervisor Terminal"/>
                            </ComboBox>
                            <materialDesign:PackIcon Kind="Monitor" 
                                                   Width="18" Height="18"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   IsHitTestVisible="False"/>
                        </Grid>

                        <!-- Sign In Button -->
                        <Button Style="{StaticResource PrimaryButton}" Click="LoginButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Sign In" VerticalAlignment="Center"/>
                                <materialDesign:PackIcon Kind="ArrowRight" 
                                                       Width="16" Height="16"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Footer Status -->
                        <Grid Margin="0,24,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Ellipse Width="6" Height="6" 
                                         Fill="{StaticResource BrandPrimaryBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0"/>
                                <TextBlock Text="Server Connected" 
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Authorized Personnel Only" 
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Opacity="0.7"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
